{
  "manifest_version": 2,
  "name": "Besterds",
  "description": "Pure Codeforces leaderboard without suspicious users.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "https://codeforces.com/*",
    "https://*.codeforces.com/*",
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://codeforces.com/contest/*/standings*",
        "https://*.codeforces.com/contest/*/standings*",
        "https://codeforces.com/gym/*/standings*",
        "https://*.codeforces.com/gym/*/standings*",
        "https://codeforces.com/group/*/contest/*/standings*",
        "https://*.codeforces.com/group/*/contest/*/standings*"
      ],
      "css": ["styles/content.css"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["src/background.js"]
  },
  "browser_action": {
    "default_title": "Besterds",
    "default_popup": "popup/popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "besterds@example.com"
    }
  }
}
